# =========================================================================
# FXTrader configuration. Copy this file to `.env` and fill in real values.
# Never commit `.env` to git.
# =========================================================================

# --- OANDA ---------------------------------------------------------------
# Get a fresh API key at https://www.oanda.com/account/manage-api-tokens
# (revoke any old ones first if you've shared them anywhere)
OANDA_API_KEY=paste-your-new-token-here

# Demo (practice) account ID — looks like 101-XXX-XXXXXXX-XXX
OANDA_ACCOUNT_ID=101-XXX-XXXXXXX-XXX
OANDA_ENV=practice

# Live account (DO NOT switch to this until backtest + demo trading prove out)
# OANDA_ACCOUNT_ID=001-XXX-XXXXXXX-XXX
# OANDA_ENV=live

# --- Trading ------------------------------------------------------------
INSTRUMENT=EUR_USD
GRANULARITY=M5

# Risk controls (all are HARD limits enforced by the engine)
RISK_PER_TRADE_PCT=0.5      # % of account equity risked per trade
MAX_TRADES_PER_DAY=4
MAX_CONCURRENT_POSITIONS=1
DAILY_LOSS_LIMIT_PCT=2.0    # kill switch trips at -2% on the day
MAX_DRAWDOWN_PCT=5.0        # hard stop at -5% from peak equity
CONSECUTIVE_LOSS_LIMIT=4    # pause 24h after this many in a row

# Trading session window (UTC). Default is London-NY overlap.
SESSION_START_UTC=07:00
SESSION_END_UTC=17:00

# Master flag. Must be `true` for the engine to act on signals at all.
# Even when true, only the configured OANDA_ENV is hit (and only if
# SHADOW_MODE=false).
TRADING_ENABLED=false

# When true, the engine generates signals and tracks hypothetical fills
# against real OANDA bid/ask, but DOES NOT place broker orders. Used for
# Test 3 of the robustness pack — observe live behaviour without
# committing capital infrastructure to a thin candidate.
SHADOW_MODE=false

# Which entry logic the live engine uses. Must be one of:
#   donchian, pullback, volsqueeze
STRATEGY_NAME=donchian

# --- Server -------------------------------------------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8765
FRONTEND_ORIGIN=http://localhost:5179
